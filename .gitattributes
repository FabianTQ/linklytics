# Normalize line endings to LF in the repo so shell scripts, Dockerfiles and
# Kubernetes manifests are not corrupted by Windows CRLF checkouts.
* text=auto eol=lf

# Windows-native scripts keep CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Treat these as binary (no EOL munging, no diff).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
