# Linklytics API — standalone env template (running the API outside Docker).
# Copy to `.env`. For docker-compose / k8s the root .env.example is used.
NODE_ENV=development
API_PORT=3001

# Point at the docker-compose host port mappings when running the API natively.
DATABASE_URL=postgresql://linklytics:change_me_in_local_env@localhost:5434/linklytics?schema=public
REDIS_URL=redis://localhost:6380

JWT_SECRET=dev_only_change_me_at_least_32_characters_long
JWT_EXPIRES_IN=7d
BCRYPT_COST=12

COOKIE_NAME=linklytics_session
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

CORS_ORIGINS=http://localhost:3000
SHORT_BASE_URL=http://localhost:3001/r

RATE_LIMIT_CREATE_PER_MIN=20
RATE_LIMIT_REDIRECT_PER_MIN=120
