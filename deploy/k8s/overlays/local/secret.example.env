# Copy this file to `secret.env` (gitignored) before deploying:
#   cp deploy/k8s/overlays/local/secret.example.env deploy/k8s/overlays/local/secret.env
# DATABASE_URL's password MUST match POSTGRES_PASSWORD.
POSTGRES_PASSWORD=linklytics_local_password
JWT_SECRET=local_kind_jwt_secret_at_least_32_characters_long
DATABASE_URL=postgresql://linklytics:linklytics_local_password@postgres:5432/linklytics?schema=public
