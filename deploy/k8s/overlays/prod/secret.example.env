# Production secrets are injected by your deployment pipeline / secret manager,
# never committed. Copy to `secret.env` (gitignored) only for local `kustomize
# build` validation.
POSTGRES_PASSWORD=replace_me
JWT_SECRET=replace_me_at_least_32_characters_long_in_prod
DATABASE_URL=postgresql://linklytics:replace_me@postgres:5432/linklytics?schema=public
