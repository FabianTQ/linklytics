# Linklytics — root environment template.
# Copy to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env
#
# This root file is consumed by docker-compose and by the Kustomize
# secretGenerator (deploy/k8s/overlays/local). Each app also ships its own
# .env.example for running it standalone (apps/api/.env.example, apps/web/.env.example).

# ───────────────────────────── Shared ──────────────────────────────
NODE_ENV=development

# ─────────────────────────── PostgreSQL ────────────────────────────
POSTGRES_USER=linklytics
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_DB=linklytics
# Host port for docker-compose (kept off 5432/5433 to avoid local clashes).
POSTGRES_HOST_PORT=5434

# ───────────────────────────── Redis ───────────────────────────────
REDIS_HOST_PORT=6380

# ────────────────────────────── API ────────────────────────────────
API_PORT=3001
# Connection strings as seen INSIDE the compose / k8s network.
DATABASE_URL=postgresql://linklytics:change_me_in_local_env@postgres:5432/linklytics?schema=public
REDIS_URL=redis://redis:6379
# Auth / security
JWT_SECRET=change_me_use_a_long_random_string_at_least_32_chars
# Short-lived access token; the refresh token (below) keeps sessions alive.
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=7
BCRYPT_COST=12
COOKIE_NAME=linklytics_session
# Set COOKIE_SECURE=true when served over HTTPS (prod).
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# CORS whitelist — comma-separated origins allowed to send credentials.
CORS_ORIGINS=http://localhost:3000
# Public base used to render short links (points at the redirect route /r).
SHORT_BASE_URL=http://localhost:3001/r
# Rate limiting (Redis-backed), requests per window per client.
RATE_LIMIT_CREATE_PER_MIN=20
RATE_LIMIT_REDIRECT_PER_MIN=120

# ────────────────────────────── Web ────────────────────────────────
WEB_PORT=3000
# Browser-visible API origin (used by the Next.js client).
NEXT_PUBLIC_API_URL=http://localhost:3001
# Server-side API origin used by Next route handlers inside the network.
API_INTERNAL_URL=http://api:3001
